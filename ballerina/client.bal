    # + return - Retrieve the number of payments on a checkout 
    remote isolated function countTheNumberOfPaymentsAttemptedOnACheckout(string token, map<string|string[]> headers = {}) returns ObjectCount|error {
        string resourcePath = string `/admin/api/2026-01/checkouts/${getEncodedUri(token)}/payments/count.json`;
        map<anydata> headerValues = {...headers};
        headerValues["X-Shopify-Access-Token"] = self.apiKeyConfig.xShopifyAccessToken;
        map<string|string[]> httpHeaders = http:getHeaderMap(headerValues);
        return self.clientEp->get(resourcePath, httpHeaders);
    }
}
